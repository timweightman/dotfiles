# Portable GitHub split: two Host aliases, same HostName.
# Git work trees rewrite remotes to github.com-work (.gitconfig-work); personal uses github.com.
# Install: either symlink to ~/.ssh/config, or from ~/.ssh/config add:
#   Include ~/dotfiles/.ssh/config
# Adjust IdentityFile paths if your key filenames differ (paths only; never commit key material).

Host github.com-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github_work
    IdentitiesOnly yes
    AddKeysToAgent yes

# Omit IdentitiesOnly so ssh can try keys from ssh-agent if this IdentityFile is not accepted first.
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_github_personal
    AddKeysToAgent yes
